{
  "name": "use-effect-reducer",
  "version": "0.7.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "tsdown",
    "changeset:publish": "changeset version && changeset publish"
  },
  "keywords": [
    "react",
    "hook",
    "reducer",
    "useReducer",
    "useEffect",
    "effect",
    "sideeffect",
    "side-effect",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/davidkpiano/useEffectReducer"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "prettier": {
    "arrowParens": "avoid",
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "author": "David Khourshid",
  "sideEffects": false,
  "devDependencies": {
    "@changesets/cli": "^2.6.5",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^28.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.20.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
